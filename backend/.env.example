# Copy this file to .env in the same folder and fill in real values.
# Nothing here is loaded automatically unless a file named exactly ".env"
# exists (see app/config.py -> load_dotenv()).

# --- Database ---
# Defaults to a local SQLite file if unset.
# DATABASE_URL=postgresql://user:password@host/dbname

# --- Auth ---
# JWT_SECRET=change-me-to-a-long-random-string
# OWNER_EMAIL=owner@rubyzensemble.in
# OWNER_PASSWORD=RubyzOwner@123

# --- Razorpay (Test Mode) ---
# Get these from Razorpay Dashboard -> Settings -> API Keys, with
# "Test Mode" toggled on (top-right switch in the dashboard).
# Test key ids start with "rzp_test_".
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret_here

# --- Shiprocket ---
# There is NO Shiprocket sandbox — these must be real (free-tier is fine)
# seller-account credentials. Build/test against throwaway, cancellable
# test orders. Docs: https://apidocs.shiprocket.in/
# SHIPROCKET_EMAIL=you@example.com
# SHIPROCKET_PASSWORD=your_shiprocket_password
# Exact pickup location "nickname" from the Shiprocket panel (Settings ->
# Company/Pickup Addresses) — calls fail without an exact match.
# SHIPROCKET_PICKUP_LOCATION=Primary
# The pickup location's actual pincode (not the nickname above) — from the
# same Settings -> Company/Pickup Addresses page, "Pin Code" column.
# Needed for live checkout rate lookups; shipment creation itself works
# without it.
# SHIPROCKET_PICKUP_PINCODE=751001
# Shared secret — set the same value in Shiprocket's webhook config
# (Settings -> API -> webhook config) and here.
# SHIPROCKET_WEBHOOK_TOKEN=a-long-random-string
