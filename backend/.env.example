# Copy this file to .env in the same folder and fill in real values.
# Nothing here is loaded automatically unless a file named exactly ".env"
# exists (see app/config.py -> load_dotenv()).

# --- Database ---
# Defaults to a local SQLite file if unset.
# DATABASE_URL=postgresql://user:password@host/dbname

# --- Auth ---
# JWT_SECRET=change-me-to-a-long-random-string
# OWNER_EMAIL=owner@rubyzensemble.in
# OWNER_PASSWORD=RubyzOwner@123

# --- Razorpay (Test Mode) ---
# Get these from Razorpay Dashboard -> Settings -> API Keys, with
# "Test Mode" toggled on (top-right switch in the dashboard).
# Test key ids start with "rzp_test_".
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret_here
